# ------------------------------------------------------------
# Backend environment sample
# ------------------------------------------------------------

# Frontend URL for CORS
FRONTEND_URL=http://127.0.0.1:5173

# ------------------------------------------------------------
# Database (choose one approach)
# ------------------------------------------------------------

# Option A: Single connection string (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_db

# Option B: Split variables (used only if DATABASE_URL is empty)
POSTGRES_DB=crm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONNECT_TIMEOUT=5

# ------------------------------------------------------------
# Optional bootstrap system admin
# ------------------------------------------------------------
SYSTEM_ADMIN_EMAIL=system.admin@example.com
SYSTEM_ADMIN_PASSWORD=ChangeThisStrongPassword123!
BOOTSTRAP_SYSTEM_ADMIN_ON_STARTUP=false

# ------------------------------------------------------------
# AWS S3 (for media storage stage)
# Leave empty for local media storage in development.
# ------------------------------------------------------------
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_FILE_OVERWRITE=false
AWS_DEFAULT_ACL=
AWS_QUERYSTRING_AUTH=false
AWS_S3_ADDRESSING_STYLE=virtual
AWS_S3_CUSTOM_DOMAIN=
